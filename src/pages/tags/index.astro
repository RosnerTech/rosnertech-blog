---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts  = await getCollection('blog', ({ data }) => !data.draft);
const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
const fmt = new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });

const tagColors: Record<string,string> = {
  docker:  'bg-[rgba(14,165,233,.12)] text-[#60a5fa] border-[rgba(14,165,233,.18)]',
  linux:   'bg-[rgba(167,139,250,.12)] text-[#c084fc] border-[rgba(167,139,250,.18)]',
  n8n:     'bg-[rgba(82,183,136,.12)] text-[#52b788] border-[rgba(82,183,136,.18)]',
  proxmox: 'bg-[rgba(248,113,113,.12)] text-[#f87171] border-[rgba(248,113,113,.18)]',
  zabbix:  'bg-[rgba(251,191,36,.12)] text-[#fbbf24] border-[rgba(251,191,36,.18)]',
  python:  'bg-[rgba(52,211,153,.12)] text-[#34d399] border-[rgba(52,211,153,.18)]',
  default: 'bg-[rgba(82,183,136,.08)] text-[#52b788] border-[rgba(82,183,136,.15)]',
};
const tc = (t: string) => tagColors[t.toLowerCase()] ?? tagColors.default;
---
<Base title="Tags">
  <div class="max-w-[1100px] mx-auto px-7 py-12">
    <div class="mb-10">
      <p class="text-[10px] text-[#52b788] tracking-[.12em] uppercase mb-2">// explorar por tema</p>
      <h1 class="font-sans text-3xl font-extrabold tracking-tight">Tags</h1>
    </div>

    <!-- nuvem de tags -->
    <div class="flex flex-wrap gap-3 mb-14">
      {allTags.map(tag => {
        const count = posts.filter(p => p.data.tags.includes(tag)).length;
        return (
          <a href={`/tags/${tag.toLowerCase()}`}
             class={`font-mono text-[12px] px-4 py-2 rounded-lg border
                     flex items-center gap-2 hover:opacity-80 transition-opacity ${tc(tag)}`}>
            {tag}
            <span class="text-[10px] opacity-60">({count})</span>
          </a>
        );
      })}
    </div>

    <!-- todos os posts agrupados por tag -->
    {allTags.map(tag => {
      const tagPosts = posts
        .filter(p => p.data.tags.includes(tag))
        .sort((a,b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
      return (
        <div class="mb-12" id={tag.toLowerCase()}>
          <div class="flex items-center gap-3 mb-5">
            <span class={`font-mono text-[11px] px-3 py-1 rounded border font-medium ${tc(tag)}`}>{tag}</span>
            <span class="text-[11px] text-[#5a6b54]">{tagPosts.length} post{tagPosts.length !== 1 ? 's' : ''}</span>
          </div>
          <div class="flex flex-col gap-2">
            {tagPosts.map(post => (
              <a href={`/blog/${post.slug}`}
                 class="flex items-center justify-between py-3 px-4
                        bg-[#111510] border border-white/[0.06] rounded-xl
                        hover:border-white/10 hover:bg-[#171e13] transition-all group">
                <span class="font-sans text-[13px] font-medium group-hover:text-[#52b788] transition-colors">
                  {post.data.title}
                </span>
                <time class="font-mono text-[11px] text-[#5a6b54] flex-shrink-0 ml-4">
                  {fmt.format(post.data.pubDate)}
                </time>
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</Base>
