---
export interface Props { size?: 'sm' | 'md' | 'lg' | 'xl' }
const { size = 'md' } = Astro.props;
const w = { sm: 180, md: 300, lg: 340, xl: 400 }[size];
const h = { sm: 36,  md: 56,  lg: 64,  xl: 76  }[size];
---
<svg width={w} height={h} viewBox="0 0 220 44" xmlns="http://www.w3.org/2000/svg" aria-label="RosnerTech">
  <defs>
    <linearGradient id="logo-gw" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#52b788"/>
      <stop offset="100%" stop-color="#74c69d"/>
    </linearGradient>
  </defs>
  <polygon points="20,4 34,4 42,18 34,32 20,32 12,18" fill="#0e1f16" stroke="#52b788" stroke-width="1.5"/>
  <line x1="20" y1="4" x2="34" y2="4" stroke="#74c69d" stroke-width="2.2" stroke-linecap="round"/>
  <polygon points="22,8 32,8 37,18 32,28 22,28 17,18" fill="none" stroke="rgba(82,183,136,0.15)" stroke-width="0.8"/>
  <text x="19" y="22" font-family="JetBrains Mono,monospace" font-size="9" font-weight="700" fill="#52b788">$_</text>
  <text x="52" y="22" font-family="JetBrains Mono,monospace" font-size="18" font-weight="700" fill="url(#logo-gw)">RosnerTech</text>
  <text font-family="JetBrains Mono,monospace" font-size="7.5" y="34">
    <tspan x="53" fill="#ffffff" opacity="0.85">Infra</tspan>
    <tspan fill="#52b788" opacity="0.5"> | </tspan>
    <tspan fill="#ffffff" opacity="0.85">DevOps</tspan>
    <tspan fill="#52b788" opacity="0.5"> | </tspan>
    <tspan fill="#ffffff" opacity="0.85">Automação</tspan>
  </text>
  <rect x="182" y="26" width="4" height="9" rx="1" fill="#52b788">
    <animate attributeName="opacity" values="1;0;1" dur="1.1s" repeatCount="indefinite"/>
  </rect>
</svg>
