---
---
<div id="cookie-banner"
  class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 hidden
         max-w-xl w-[calc(100%-3rem)]
         bg-[#111510] border border-white/10 rounded-2xl
         px-4 py-3 flex items-center gap-4
         shadow-[0_16px_48px_rgba(0,0,0,0.6)]">
  <span class="text-lg flex-shrink-0">🍪</span>
  <p class="text-[11px] text-[#5a6b54] leading-relaxed flex-1">
    Usamos cookies para analytics. Leia nossa
    <a href="/privacidade" class="text-[#60a5fa] hover:underline">Política de Privacidade</a>.
  </p>
  <div class="flex gap-2 flex-shrink-0">
    <button id="cookie-reject"
      class="font-mono text-[11px] px-3 py-1.5 rounded-lg
             border border-white/10 text-[#5a6b54] hover:text-white transition-colors">
      Recusar
    </button>
    <button id="cookie-accept"
      class="font-mono text-[11px] px-3 py-1.5 rounded-lg
             bg-[#52b788] text-black font-medium hover:bg-[#74c69d] transition-colors">
      Aceitar
    </button>
  </div>
</div>
<script>
  const COOKIE_KEY = 'rt-cookie-consent';
  const banner = document.getElementById('cookie-banner');
  if (!localStorage.getItem(COOKIE_KEY)) banner?.classList.remove('hidden');
  document.getElementById('cookie-accept')?.addEventListener('click', () => {
    localStorage.setItem(COOKIE_KEY, 'accepted');
    banner?.classList.add('hidden');
  });
  document.getElementById('cookie-reject')?.addEventListener('click', () => {
    localStorage.setItem(COOKIE_KEY, 'rejected');
    banner?.classList.add('hidden');
  });
</script>
